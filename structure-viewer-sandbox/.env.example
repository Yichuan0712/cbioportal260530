# Set VITE_USE_MOCK_DATA=true to revert to fixtures-only (no network).
# VITE_USE_MOCK_DATA=false

# Gene — default SOX9 (screenshot: NM_000346 / ENST00000245479, 509 aa)
# VITE_HUGO_GENE=SOX9

# VITE_USE_MOCK_MUTATIONS=true

# Optional PDB preference when G2S returns many chains (leave empty for auto)
# VITE_PREFERRED_PDB=

# Official backends (Vite dev proxies these paths):
# VITE_CBIOPORTAL_URL=/cbioportal-api          -> www.cbioportal.org
# VITE_G2S_URL=/g2s-api                        -> g2s.genomenexus.org
# VITE_GENOMENEXUS_URL=/genomenexus-api        -> v1.genomenexus.org

# Match a specific Results View query: comma-separated studyId list
# (profiles are resolved via /api/studies/{studyId}/molecular-profiles)
# VITE_CBIOPORTAL_STUDY_IDS=msk_impact_2017,brca_tcga

# Fallback when VITE_CBIOPORTAL_STUDY_IDS is cleared: explicit molecularProfileId list
# VITE_CBIOPORTAL_MUTATION_PROFILES=msk_impact_2017_mutations,brca_tcga_mutations

# Local G2S override (optional): point proxy target in vite.config.ts or set direct URL
# VITE_G2S_URL=https://localhost:5443
