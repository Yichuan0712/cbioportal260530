# Set VITE_USE_MOCK_DATA=true to revert to fixtures-only (no network).
# Default (unset or false): live SOX9 + msk_impact_50k_2026 (matches official Results link).
# VITE_USE_MOCK_DATA=false

# Gene — default SOX9 (official Mutations tab: ENST00000245479)
# VITE_HUGO_GENE=SOX9

# Study — default msk_impact_50k_2026 only (same as cancer_study_list in official URL)
# VITE_CBIOPORTAL_STUDY_IDS=msk_impact_50k_2026

# VITE_USE_MOCK_MUTATIONS=true

# Leave empty so PDB auto-select matches official (top G2S chain; name may be SOX17 on RCSB)
# VITE_PREFERRED_PDB=

# RefSeq label in meta column
# VITE_REFSEQ_TRANSCRIPT=NM_000346

# Official backends (Vite dev proxies these paths):
# VITE_CBIOPORTAL_URL=/cbioportal-api          -> www.cbioportal.org
# VITE_G2S_URL=/g2s-api                        -> local G2S (vite.config: localhost:5443)
# VITE_GENOMENEXUS_URL=/genomenexus-api        -> v1.genomenexus.org

# Widen studies (not the default official page):
# VITE_CBIOPORTAL_STUDY_IDS=msk_impact_2017,msk_impact_50k_2026,brca_tcga

# Local G2S override (optional)
# VITE_G2S_URL=https://localhost:5443
